@startuml CU06_CerrarSesion
left to right direction
skinparam dpi 150
skinparam shadowing false
skinparam packageStyle rectangle

actor "Usuario\n(autenticado)" as User

rectangle "Sistema Web de Mascotas 3D" {
  usecase "Gestionar sesión" as UC_Session
  usecase "Detectar inactividad" as UC_DetectIdle
  usecase "Expirar sesión" as UC_ExpireSession
  usecase "Invalidar credenciales" as UC_InvalidateCreds
  usecase "Redirigir a login" as UC_RedirectLogin
}

User -- UC_Session
UC_Session ..> UC_DetectIdle : <<include>>
UC_Session ..> UC_ExpireSession : <<include>>
UC_ExpireSession ..> UC_InvalidateCreds : <<include>>
UC_ExpireSession ..> UC_RedirectLogin : <<include>>

@enduml
