<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/fondo_principal">

    <!-- Barra superior -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="12dp"
        android:background="@color/fondo_barra">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="⚡ Conversor SOAP"
            android:textColor="@color/titulo"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/lblUsuario"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/texto_secundario"
            android:textSize="13sp"
            android:layout_marginEnd="12dp" />

        <Button
            android:id="@+id/btnSalir"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="🚪 Salir"
            android:textColor="@color/error"
            android:textSize="12sp"
            android:backgroundTint="@color/fondo_campo" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="24dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="📐 Conversión de Unidades"
                android:textColor="@color/titulo"
                android:textSize="20sp"
                android:textStyle="bold"
                android:gravity="center"
                android:layout_marginBottom="20dp" />

            <!-- Categoría -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="📋 Categoría"
                android:textColor="@color/etiqueta"
                android:textSize="14sp"
                android:layout_marginBottom="4dp" />

            <Spinner
                android:id="@+id/spnCategoria"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="@color/fondo_campo"
                android:padding="8dp"
                android:layout_marginBottom="16dp" />

            <!-- Valor -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="🔢 Valor"
                android:textColor="@color/etiqueta"
                android:textSize="14sp"
                android:layout_marginBottom="4dp" />

            <EditText
                android:id="@+id/txtValor"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:hint="Ingrese el valor"
                android:textColor="@color/texto_principal"
                android:textColorHint="@color/texto_hint"
                android:background="@color/fondo_campo"
                android:padding="12dp"
                android:inputType="numberDecimal"
                android:layout_marginBottom="16dp" />

            <!-- Unidades -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginEnd="8dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="📥 Origen"
                        android:textColor="@color/etiqueta"
                        android:textSize="14sp"
                        android:layout_marginBottom="4dp" />

                    <Spinner
                        android:id="@+id/spnDesde"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:background="@color/fondo_campo"
                        android:padding="8dp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="8dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="📤 Destino"
                        android:textColor="@color/etiqueta"
                        android:textSize="14sp"
                        android:layout_marginBottom="4dp" />

                    <Spinner
                        android:id="@+id/spnHasta"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:background="@color/fondo_campo"
                        android:padding="8dp" />
                </LinearLayout>
            </LinearLayout>

            <!-- Botón Convertir -->
            <Button
                android:id="@+id/btnConvertir"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:text="🔄 Convertir"
                android:textColor="@android:color/white"
                android:backgroundTint="@color/acento_primario"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginTop="20dp" />

            <!-- Resultado -->
            <TextView
                android:id="@+id/lblResultado"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/exito"
                android:textSize="18sp"
                android:textStyle="bold"
                android:gravity="center"
                android:padding="16dp"
                android:layout_marginTop="16dp"
                android:background="@color/fondo_resultado"
                android:visibility="gone" />

            <!-- Error -->
            <TextView
                android:id="@+id/lblError"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/error"
                android:textSize="13sp"
                android:padding="12dp"
                android:layout_marginTop="8dp"
                android:visibility="gone" />
        </LinearLayout>
    </ScrollView>
</LinearLayout>
